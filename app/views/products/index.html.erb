<h1>Products</h1>

<%= link_to "New Product", new_product_path, class: "btn btn-primary" %>

<hr>

<% @products.each do |product| %>
  <div>
    <h3>
      <%= link_to product.name, product_path(product) %>
    </h3>

    <p><%= product.description %></p>
    <p>Price: $<%= product.price %></p>
  </div>

  <hr>
<% end %>
