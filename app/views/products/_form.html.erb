<%= simple_form_for @product do |f| %>
  <%= f.input :name %>
  <%= f.input :description %>
  <%= f.input :price %>
  <%= f.input :available %>
  <%= f.collection_select :category_id, Category.all, :id, :name %>
  <%= f.input :photos, as: :file, input_html: { multiple: true }  %>

  <%= f.submit class: "btn btn-primary" %>
<% end %>
